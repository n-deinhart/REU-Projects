        RowBox[{"n", "+", "1"}], ",", "j"}], "]"}], "*", 
      RowBox[{"Binomial", "[", 
       RowBox[{
        RowBox[{"n", "+", "k", "-", 
         RowBox[{
          RowBox[{"(", 
